{
  "name": "agent-phonon",
  "version": "0.8.2",
  "description": "agent-phonon device daemon — connects to servers, schedules local AI agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-phonon": "./dist/cli.js"
  },
  "main": "./dist/daemon.js",
  "types": "./dist/daemon.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsup",
    "build:test": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build:test && node --test dist-test/config.test.js",
    "test:e2e": "pnpm build:test && node --test dist-test/daemon.test.js dist-test/obs.test.js",
    "test:all": "pnpm build:test && node --test dist-test/*.test.js"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@agent-phonon/core": "workspace:*",
    "@agent-phonon/protocol": "workspace:*",
    "@agent-phonon/test-server": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3"
  },
  "author": "agent-phonon contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackerphysics/agent-phonon.git",
    "directory": "packages/daemon"
  },
  "homepage": "https://github.com/hackerphysics/agent-phonon#readme",
  "bugs": {
    "url": "https://github.com/hackerphysics/agent-phonon/issues"
  }
}
